# Conveyor — environment variables (all free-tier, $0)
# Copy to `.env.local` and fill in. NEVER commit the filled-in file.

# --- Upstash Redis (REST) ---
# From https://console.upstash.com → your Redis database → "REST API"
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Upstash QStash ---
# From https://console.upstash.com/qstash → "Request Builder" / "API Keys"
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- App URL (the PUBLIC url QStash calls back) ---
# Leave EMPTY locally — when running `npx @upstash/qstash-cli dev`, the local
# dev server reaches localhost:3000 for you. On Vercel, set this to your prod
# domain (e.g. https://conveyor.vercel.app). VERCEL_URL is used as a fallback.
CONVEYOR_APP_URL=
